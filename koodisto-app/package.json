{
    "name": "koodisto-app",
    "version": "0.1.0",
    "private": true,
    "dependencies": {
        "@daypicker/react": "10.0.1",
        "@tanstack/react-table": "8.21.3",
        "axios": "1.18.1",
        "date-fns": "4.4.0",
        "jotai": "1.13.1",
        "papaparse": "5.5.3",
        "react": "18.3.1",
        "react-accessible-accordion": "5.0.1",
        "react-dom": "18.3.1",
        "react-hook-form": "7.68.0",
        "react-intl": "6.8.9",
        "react-notifications-component": "4.0.1",
        "react-router-dom": "6.30.4",
        "react-select": "5.10.2",
        "reactjs-popup": "2.0.6",
        "styled-components": "5.3.11",
        "styled-system": "5.1.5"
    },
    "devDependencies": {
        "@eslint/js": "9.39.4",
        "@formatjs/intl": "2.10.15",
        "@iconify/react": "3.2.2",
        "@playwright/test": "1.61.1",
        "@types/node": "24.10.15",
        "@types/papaparse": "5.5.2",
        "@types/react": "18.3.31",
        "@types/react-dom": "18.3.7",
        "@types/styled-components": "5.1.36",
        "@types/styled-system": "5.1.25",
        "concurrently": "10.0.3",
        "css-loader": "7.1.4",
        "eslint": "9.39.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-jsx-a11y": "6.10.2",
        "eslint-plugin-prettier": "5.5.6",
        "eslint-plugin-react": "7.37.5",
        "file-loader": "6.2.0",
        "fork-ts-checker-webpack-plugin": "9.1.0",
        "html-webpack-plugin": "5.6.7",
        "mini-css-extract-plugin": "2.10.2",
        "prettier": "3.8.3",
        "source-map-loader": "5.0.0",
        "style-loader": "4.0.0",
        "ts-loader": "9.6.2",
        "tsx": "4.22.4",
        "typescript": "5.9.3",
        "typescript-eslint": "8.62.1",
        "webpack": "5.108.3",
        "webpack-cli": "7.1.0",
        "webpack-dev-server": "5.2.5",
        "webpack-manifest-plugin": "5.0.1"
    },
    "scripts": {
        "start": "NODE_ENV=development npx webpack serve",
        "mock-api": "npm --prefix ./mock-api run mock-api",
        "build": "GENERATE_SOURCEMAP=false NODE_ENV=production npx webpack --mode production",
        "test": "node --import tsx --test ./src/**/*.test.ts",
        "lint": "eslint -c eslint.config.mjs",
        "playwright": "PLAYWRIGHT=true concurrently -s first -k 'npm run mock-api' 'npm run start' 'sleep 5 && npx playwright test'",
        "playwright:install": "playwright install-deps && playwright install chromium && npm --prefix mock-api ci"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "proxy": "http://localhost:9000"
}
